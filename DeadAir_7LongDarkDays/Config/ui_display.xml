<?xml version="1.0" encoding="UTF-8"?>
<configs>

  <!-- ========================= -->
  <!-- Carnivore custom display types -->
  <!-- These are custom, so full definitions are fine -->
  <!-- ========================= -->
  <append xpath="/ui_display_info/item_display">

    <item_display_info display_type="foodRawMeatCarnivore" display_group="groupConsumables">
      <display_entry name="$foodAmountAdd" title_key="statFoodAmount"/>
      <display_entry name="foodHealthAmount" title_key="statHealthAmount"/>
      <display_entry name=".foodStaminaBonusAdd" title_key="statFoodStaminaBonus"/>
      <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
      <display_entry name="dSmell" title_key="statFoodSmellAlways" display_type="Bool"/>
      <display_entry name="dSmellUse" title_key="statFoodSmell"/>
    </item_display_info>

    <item_display_info display_type="foodCarnivore" display_group="groupConsumables">
      <display_entry name="$foodAmountAdd" title_key="statFoodAmount"/>
      <display_entry name="foodHealthAmount" title_key="statHealthAmount"/>
      <display_entry name=".foodStaminaBonusAdd" title_key="statFoodStaminaBonus"/>
      <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
      <display_entry name="dSmellUse" title_key="statFoodSmell"/>
    </item_display_info>

    <item_display_info display_type="foodCarnivoreWater" display_group="groupConsumables">
      <display_entry name="$foodAmountAdd" title_key="statFoodAmount"/>
      <display_entry name="$waterAmountAdd" title_key="statWaterAmount"/>
      <display_entry name="foodHealthAmount" title_key="statHealthAmount"/>
      <display_entry name=".foodStaminaBonusAdd" title_key="statFoodStaminaBonus"/>
      <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
      <display_entry name="dSmellUse" title_key="statFoodSmell"/>
    </item_display_info>

    <item_display_info display_type="drinkDeadAirParasiteTea" display_group="groupConsumables">
      <display_entry name="$waterAmountAdd" title_key="statWaterAmount"/>
      <display_entry name="ldTreatsParasites" title_key="ldTreatsParasites" display_type="Bool"/>
      <display_entry name="ldParasiteTreatmentTypeTea" title_key="ldParasiteTreatmentTypeTea" display_type="Bool"/>
    </item_display_info>

    <item_display_info display_type="drinkDeadAirParasiteTonic" display_group="groupConsumables">
      <display_entry name="$waterAmountAdd" title_key="statWaterAmount"/>
      <display_entry name="ldTreatsParasites" title_key="ldTreatsParasites" display_type="Bool"/>
      <display_entry name="ldParasiteTreatmentTypeTonic" title_key="ldParasiteTreatmentTypeTonic" display_type="Bool"/>
    </item_display_info>

    <item_display_info display_type="drinkDeadAirColonCleanse" display_group="groupConsumables">
      <display_entry name="$waterAmountAdd" title_key="statWaterAmount"/>
      <display_entry name="ldRemovesBodyOdor" title_key="ldRemovesBodyOdor" display_type="Bool"/>
    </item_display_info>

  </append>

  <!-- ========================= -->
  <!-- Patch existing vanilla display types -->
  <!-- Do NOT redefine them -->
  <!-- ========================= -->

  <!-- foodRawMeat: herbivore raw meats -->
  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodRawMeat'][not(display_entry[@name='dDysenteryRisk'])]">
    <display_entry name="dDysenteryRisk" title_key="statDysenteryRisk" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodRawMeat'][not(display_entry[@name='ldParasiteChance'])]">
    <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodRawMeat'][not(display_entry[@name='dSmell'])]">
    <display_entry name="dSmell" title_key="statFoodSmellAlways" display_type="Bool"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodRawMeat'][not(display_entry[@name='dSmellUse'])]">
    <display_entry name="dSmellUse" title_key="statFoodSmell"/>
  </append>

  <!-- food: herbivore grilled meats -->
  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='food'][not(display_entry[@name='dDysenteryRisk'])]">
    <display_entry name="dDysenteryRisk" title_key="statDysenteryRisk" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='food'][not(display_entry[@name='ldParasiteChance'])]">
    <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='food'][not(display_entry[@name='dSmellUse'])]">
    <display_entry name="dSmellUse" title_key="statFoodSmell"/>
  </append>

  <!-- foodWaterNegative: herbivore charred meats -->
  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodWaterNegative'][not(display_entry[@name='dDysenteryRisk'])]">
    <display_entry name="dDysenteryRisk" title_key="statDysenteryRisk" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodWaterNegative'][not(display_entry[@name='ldParasiteChance'])]">
    <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodWaterNegative'][not(display_entry[@name='dSmellUse'])]">
    <display_entry name="dSmellUse" title_key="statFoodSmell"/>
  </append>

  <!-- foodWater: herbivore boiled meats -->
  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodWater'][not(display_entry[@name='dDysenteryRisk'])]">
    <display_entry name="dDysenteryRisk" title_key="statDysenteryRisk" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodWater'][not(display_entry[@name='ldParasiteChance'])]">
    <display_entry name="ldParasiteChance" title_key="ldStatParasiteChance" display_type="Percent" negative_preferred="true"/>
  </append>

  <append xpath="/ui_display_info/item_display/item_display_info[@display_type='foodWater'][not(display_entry[@name='dSmellUse'])]">
    <display_entry name="dSmellUse" title_key="statFoodSmell"/>
  </append>

</configs>