<configs>

  <!-- ===================================== -->
  <!-- BANDAGES: MOST CLEAN -> DIRTY (except airdropMedicine) -->
  <!-- ===================================== -->

  <!-- helper pattern: remove clean bandage entry in each group, add dirty (weight 4) + clean (weight 1) -->
  <!-- groupQuestMedical -->
  <remove xpath="//lootgroup[@name='groupQuestMedical']/item[@name='medicalFirstAidBandage']"/>
  <append xpath="//lootgroup[@name='groupQuestMedical']">
    <item name="medicalFirstAidBandageDirty" prob="4"/>
    <item name="medicalFirstAidBandage" prob="1"/>
  </append>

