    <item name="resourceEthanol" prob="1"/>
  </append>

  <remove xpath="//lootgroup[@name='groupLiquorBonus']/item[@name='drinkJarBeer']"/>
  <append xpath="//lootgroup[@name='groupLiquorBonus']">
    <item name="drinkJarBeer" prob="1"/>
    <item name="resourceEthanol" prob="1"/>
  </append>

  <!-- ===================================== -->
  <!-- ETHANOL: add to select medical groups -->
  <!-- ===================================== -->

  <append xpath="//lootgroup[@name='survivalMedical']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <append xpath="//lootgroup[@name='groupQuestMedical']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <append xpath="//lootgroup[@name='groupMedicalAll']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <append xpath="//lootgroup[@name='groupMedicalCommon']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <append xpath="//lootgroup[@name='groupMedicalUncommon']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <append xpath="//lootgroup[@name='groupZpackNurseB']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <append xpath="//lootgroup[@name='groupZpackLab01']">
    <item name="resourceEthanol" prob="1"/>
  </append>

  <!-- Trader display case -->
  <append xpath="/lootcontainers">
    <lootcontainer name="daTraderDisplayCaseGuns" count="1,2" size="6,4" sound_open="UseActions/open_cooler" sound_close="UseActions/close_chest">
      <item name="ammo9mmBulletBall" count="10,60" prob="0.6"/>
      <item name="ammo762mmBulletBall" count="10,60" prob="0.6"/>
      <item name="resourceGunPowder" count="10,50" prob="0.5"/>
      <item name="resourceMechanicalParts" count="1,10" prob="0.4"/>
      <item name="gunHandgunT1Pistol" count="1,1" prob="0.10"/>
    </lootcontainer>
  </append>

  <!-- Remove bandage / purifier entries -->
  <remove xpath="//lootgroup[@name='groupZpackNurseA']/item[@name='medicalBandage']"/>
  <remove xpath="//item[@name='modArmorWaterPurifier']"/>

  <!-- DeadAir mannequin -->
  <append xpath="/lootcontainers">
    <lootcontainer name="daMannequinArmor" count="1" size="4,3" sound_open="open_clothes_rack" sound_close="close_clothes_rack" destroy_on_close="empty">
      <item name="armorParts" count="5" prob="1"/>
      <item name="resourceCloth" count="5,25" prob="0.25"/>
      <item name="resourceLeather" count="2,12" prob="0.15"/>
      <item name="resourceScrapIron" count="2,15" prob="0.15"/>
    </lootcontainer>
  </append>

  <append xpath="/lootcontainers">
    <lootcontainer name="daPalletAmmo" count="1" size="4,3" sound_open="UseActions/open_cardboard" sound_close="UseActions/close_cardboard">
      <item name="ammo9mmBulletBall" count="10" prob="1"/>
    </lootcontainer>
  </append>

  <!-- Airdrop adjustments -->
  <set xpath="/lootcontainers/lootcontainer[@name='airDrop']/@size">9,4</set>
  <set xpath="/lootcontainers/lootgroup[@name='groupAirDrop02']/@count">all</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropfood']/item[@group='cannedfood']/@count">2,4</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropdrink']/item[@name='drinkJarBoiledWater']/@count">2,4</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropdrink']/item[@name='drinkJarGoldenRodTea']/@count">2,3</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropdrink']/item[@name='drinkJarRedTea']/@count">2,3</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropdrink']/item[@name='drinkJarCoffee']/@count">2,3</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropdrink']/item[@name='drinkJarYuccaJuice']/@count">2,3</set>

  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='drugPainkillers']/@count">2,4</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='medicalFirstAidKit']/@count">1,3</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='drugVitamins']/@count">1,2</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='drugSteroids']/@count">1,2</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='foodHoney']/@count">1,3</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='drugHerbalAntibiotics']/@count">1,2</set>
  <set xpath="/lootcontainers/lootgroup[@name='airdropMedicine']/item[@name='drugAntibiotics']/@count">1,2</set>

  <append xpath="/lootcontainers/lootgroup[@name='groupAirDrop03']">
    <item group="groupQuestAmmoCraftingBundle"/>
    <item group="groupQuestForgedIron"/>
    <item group="groupQuestForgedSteel"/>
    <item group="groupQuestT3Firearms"/>
    <item group="groupQuestTimedCharges"/>
  </append>

  <append xpath="/lootcontainers/lootgroup[@name='groupAirDrop']">
    <item group="groupAirDrop03" count="1"/>
  </append>

</configs>