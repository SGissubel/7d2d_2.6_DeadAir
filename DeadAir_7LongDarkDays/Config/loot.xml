  <remove xpath="//lootgroup[@name='groupHardenedChestT4_05']/item[@name='medicalFirstAidBandage']"/>
  <append xpath="//lootgroup[@name='groupHardenedChestT4_05']">
    <item name="medicalFirstAidBandageDirty" prob="4"/>
    <item name="medicalFirstAidBandage" prob="1"/>
  </append>

  <!-- ===================================== -->
  <!-- BEER: 50/50 beer vs ethanol           -->
  <!-- ===================================== -->

  <remove xpath="//lootgroup[@name='groupDrinksUncommon']/item[@name='drinkJarBeer']"/>
  <append xpath="//lootgroup[@name='groupDrinksUncommon']">
    <item name="drinkJarBeer" prob="1"/>
    <item name="resourceEthanol" prob="1"/>
  </append>

  <remove xpath="//lootgroup[@name='groupBeerCooler01']/item[@name='drinkJarBeer']"/>
  <append xpath="//lootgroup[@name='groupBeerCooler01']">
    <item name="drinkJarBeer" prob="1"/>
    <item name="resourceEthanol" prob="1"/>
  </append>

  <remove xpath="//lootgroup[@name='groupLiquorSmall01']/item[@name='drinkJarBeer']"/>
  <append xpath="//lootgroup[@name='groupLiquorSmall01']">
    <item name="drinkJarBeer" prob="1"/>
    <item name="resourceEthanol" prob="1"/>
  </append>

  <remove xpath="//lootgroup[@name='groupLiquorMed01']/item[@name='drinkJarBeer']"/>
  <append xpath="//lootgroup[@name='groupLiquorMed01']">
