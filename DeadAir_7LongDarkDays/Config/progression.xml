<?xml version="1.0" encoding="UTF-8"?>
<configs>

  <remove xpath="/progression/perks/perk[@name='perkParkour']"/>

  <append xpath="/progression/perks">
    <perk name="perkParkour" parent="skillAgilityAthletics" name_key="perkParkourName" desc_key="perkParkourDesc" icon="ui_game_symbol_parkour">
      <level_requirements level="1">
        <requirement name="ProgressionLevel" progression_name="attAgility" operation="GTE" value="2" desc_key="reqAgilityLevel02"/>
      </level_requirements>
      <level_requirements level="2">
        <requirement name="ProgressionLevel" progression_name="attAgility" operation="GTE" value="5" desc_key="reqAgilityLevel05"/>
      </level_requirements>
      <level_requirements level="3">
        <requirement name="ProgressionLevel" progression_name="attAgility" operation="GTE" value="8" desc_key="reqAgilityLevel08"/>
      </level_requirements>

      <effect_group>
        <passive_effect name="JumpStrength" operation="perc_add" level="2,3" value=".05,.12"/>
        <triggered_effect trigger="onSelfProgressionUpdate" action="ModifyCVar" cvar="$parkourBonus" operation="set" value="0,0,.004,.010"/>
        <passive_effect name="StaminaLoss" operation="perc_add" level="1,2,3" value="-.08,-.15,-.22" tags="jumping"/>

        <effect_description level="1" desc_key="perkParkourRank1Desc" long_desc_key="perkParkourRank1LongDesc"/>
        <effect_description level="2" desc_key="perkParkourRank2Desc" long_desc_key="perkParkourRank2LongDesc"/>
        <effect_description level="3" desc_key="perkParkourRank3Desc" long_desc_key="perkParkourRank3LongDesc"/>
    </effect_group>
    </perk>
  </append>

  <insertAfter xpath="/progression/crafting_skills/crafting_skill[@name='craftingFood']/effect_group/passive_effect[last()]">
    <passive_effect name="RecipeTagUnlocked" operation="base_set" level="6,100" value="1" tags="foodGrilledMeatCarnivore,foodGrilledMeatHerbivore"/>
    <passive_effect name="RecipeTagUnlocked" operation="base_set" level="8,100" value="1" tags="foodBoiledMeatCarnivore,foodBoiledMeatHerbivore"/>
    <!-- <passive_effect name="RecipeTagUnlocked" operation="base_set" level="30,100" value="1" tags="drinkTeaParasiteCleanse,drinkColonCleanseTonic"/> -->
  </insertAfter>
