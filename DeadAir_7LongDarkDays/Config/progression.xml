  <insertAfter xpath="/progression/crafting_skills/crafting_skill[@name='craftingMedical']/effect_group/passive_effect[last()]">
    <passive_effect name="RecipeTagUnlocked" operation="base_set" level="50,100" value="1" tags="medicalAnthelminticTonic"/>
  </insertAfter>
  <insertAfter xpath="/progression/crafting_skills/crafting_skill[@name='craftingMedical']/display_entry[last()]">
    <display_entry
        icon="medicalAnthelminticTonic"
        name_key="medicalT5-1"
        has_quality="false"
        unlock_level="50">
      <unlock_entry item="medicalAnthelminticTonic" unlock_tier="1"/>
