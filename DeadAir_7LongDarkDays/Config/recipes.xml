<?xml version="1.0" encoding="UTF-8"?>
<configs>

  <!-- Remove vanilla cooked meat recipes -->
  <remove xpath="/recipes/recipe[@name='foodCharredMeat']"/>
  <remove xpath="/recipes/recipe[@name='foodGrilledMeat']"/>
  <remove xpath="/recipes/recipe[@name='foodBoiledMeat']"/>

  <!-- ===================================================== -->
  <!-- HERBIVORE -> normal cooked meats (unchanged logic)     -->
  <!-- ===================================================== -->
  <!-- (Keep your existing herbivore blocks as-is) -->


  <!-- ===================================================== -->
  <!-- CARNIVORE -> carnivore cooked variants (with reductions) -->
  <!-- ===================================================== -->
  <append xpath="/recipes">

    <!-- CHARRED -->
    <recipe name="foodCharredMeatCarnivore" count="1" craft_area="campfire" tags="perkMasterChef">
      <ingredient name="foodRawMeatBear" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatBear"/>
      </effect_group>
    </recipe>

    <recipe name="foodCharredMeatCarnivore" count="1" craft_area="campfire" tags="perkMasterChef">
      <ingredient name="foodRawMeatWolf" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatWolf"/>
      </effect_group>
    </recipe>

    <recipe name="foodCharredMeatCarnivore" count="1" craft_area="campfire" tags="perkMasterChef">
      <ingredient name="foodRawMeatMountainLion" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatMountainLion"/>
      </effect_group>
    </recipe>

    <recipe name="foodCharredMeatCarnivore" count="1" craft_area="campfire" tags="perkMasterChef">
      <ingredient name="foodRawMeatSnake" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatSnake"/>
      </effect_group>
    </recipe>


    <!-- GRILLED -->
    <recipe name="foodGrilledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingGrill" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatBear" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatBear"/>
      </effect_group>
    </recipe>

    <recipe name="foodGrilledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingGrill" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatWolf" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatWolf"/>
      </effect_group>
    </recipe>

    <recipe name="foodGrilledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingGrill" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatMountainLion" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatMountainLion"/>
      </effect_group>
    </recipe>

    <recipe name="foodGrilledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingGrill" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatSnake" count="5"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatSnake"/>
      </effect_group>
    </recipe>


    <!-- BOILED -->
    <recipe name="foodBoiledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingPot" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatBear" count="5"/>
      <ingredient name="drinkJarBoiledWater" count="1"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatBear"/>
      </effect_group>
    </recipe>

    <recipe name="foodBoiledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingPot" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatWolf" count="5"/>
      <ingredient name="drinkJarBoiledWater" count="1"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatWolf"/>
      </effect_group>
    </recipe>

    <recipe name="foodBoiledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingPot" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatMountainLion" count="5"/>
      <ingredient name="drinkJarBoiledWater" count="1"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatMountainLion"/>
      </effect_group>
    </recipe>

    <recipe name="foodBoiledMeatCarnivore" count="1" craft_area="campfire" craft_tool="toolCookingPot" tags="perkMasterChef,learnable">
      <ingredient name="foodRawMeatSnake" count="5"/>
      <ingredient name="drinkJarBoiledWater" count="1"/>
      <effect_group>
        <passive_effect name="CraftingIngredientCount" level="1,3" operation="base_add" value="-1,-2" tags="foodRawMeatSnake"/>
      </effect_group>
    </recipe>

  </append>

  <!-- ===================================================== -->
  <!-- Weapons Repair Kit recipe (workbench)                  -->
  <!-- ===================================================== -->
  <append xpath="/recipes">
    <recipe name="resourceWeaponRepairKit" count="1" craft_area="workbench" tags="perkMasterChef">
      <ingredient name="resourceForgedIron" count="1"/>
      <ingredient name="resourceDuctTape" count="1"/>
      <ingredient name="resourceMechanicalParts" count="2"/>
      <ingredient name="resourceOil" count="1"/>
    </recipe>
  </append>

  <!-- Update clean bandage crafting: require ethanol -->
  <!-- If your base game already has a recipe for medicalFirstAidBandage, remove it first -->
  <remove xpath="/recipes/recipe[@name='medicalFirstAidBandage']"/>

  <append xpath="/recipes">
    <recipe name="medicalFirstAidBandage" count="1">
      <ingredient name="resourceCloth" count="2"/>
      <ingredient name="resourceEthanol" count="1"/>
    </recipe>
  </append>

  <!-- Pocket sterilize dirty -> clean -->
  <append xpath="/recipes">
    <recipe name="medicalFirstAidBandage" count="1">
      <ingredient name="medicalFirstAidBandageDirty" count="1"/>
      <ingredient name="resourceEthanol" count="1"/>
    </recipe>
  </append>


  <!-- Treatment via CLEAN bandage + honey -->
  <append xpath="/recipes">
    <recipe name="medicalWoundInfectionTreatment" count="1">
      <ingredient name="medicalFirstAidBandage" count="1"/>
      <ingredient name="foodHoney" count="1"/>
    </recipe>
  </append>

  <!-- Treatment via CLEAN bandage + ethanol -->
  <append xpath="/recipes">
    <recipe name="medicalWoundInfectionTreatment" count="1">
      <ingredient name="medicalFirstAidBandage" count="1"/>
      <ingredient name="resourceEthanol" count="1"/>
    </recipe>
  </append>

  

  <remove xpath="//recipe[@name='medicalBandage']"/>
  <remove xpath="//recipe[@name='modArmorWaterPurifier']"/>



  <!-- ===================================================== -->
  <!-- Build the Weapon Repair Bench                         -->
  <!-- ===================================================== -->
  <append xpath="/recipes">
      <recipe name="cntDeadAirWeaponRepairBench" count="1" craft_area="workbench">
          <ingredient name="resourceForgedIron" count="25"/>
          <ingredient name="resourceMechanicalParts" count="20"/>
          <ingredient name="resourceElectricParts" count="8"/>
          <ingredient name="resourceScrapPolymers" count="10"/>
          <ingredient name="resourceDuctTape" count="5"/>
      </recipe>
  </append>

  <append xpath="/recipes">
      <recipe name="resourceWeaponRepairKit" count="1" craft_area="deadairWeaponRepairBench">
          <ingredient name="resourceForgedIron" count="1"/>
          <ingredient name="resourceDuctTape" count="1"/>
          <ingredient name="resourceMechanicalParts" count="2"/>
          <ingredient name="resourceOil" count="1"/>
      </recipe>
  </append>




  <!-- ====================================== -->
  <!-- Parasite Cleanse Tea                   -->
  <!-- ====================================== -->
  <append xpath="/recipes">
    <recipe name="drinkTeaParasiteCleanse" count="1" craft_area="campfire" craft_tool="toolCookingPot" tags="learnable">
      <ingredient name="drinkJarBoiledWater" count="1"/>
      <ingredient name="foodCropMushrooms" count="2"/>
      <ingredient name="resourceCropChrysanthemumPlant" count="2"/>
      <ingredient name="foodHoney" count="1"/>
    </recipe>
  </append>

  <!-- ====================================== -->
  <!-- Anthelmintic Tonic                     -->
  <!-- ====================================== -->
  <append xpath="/recipes">
    <recipe name="medicalAnthelminticTonic" count="1" craft_area="chemistryStation" tags="learnable">
      <ingredient name="resourceAcid" count="2"/>
      <ingredient name="foodCropMushroomsRadiated" count="4"/>
      <ingredient name="foodHoney" count="1"/>
      <ingredient name="drinkJarBoiledWater" count="1"/>
    </recipe>
  </append>



  <append xpath="/recipes">

    <recipe name="drinkColonCleanseTonic" count="1" craft_area="campfire" tags="learnable">
      <ingredient name="drinkJarBoiledWater" count="1"/>
      <ingredient name="resourceCropGoldenrodPlant" count="2"/>
      <ingredient name="resourceCropChrysanthemumPlant" count="2"/>
      <ingredient name="foodCropYuccaFruit" count="1"/>
      <ingredient name="resourceCropAloeLeaf" count="1"/>
      <ingredient name="resourceCoal" count="1"/>
      <ingredient name="foodHoney" count="1"/>
    </recipe>

  </append>

</configs>
