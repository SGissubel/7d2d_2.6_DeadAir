<?xml version="1.0" encoding="UTF-8"?>
<configs>

  <!-- Make trader display cases lootable (keep same models, just add loot behavior) -->

  <append xpath="/blocks/block[@name='cntDisplayCaseNoLootLeft']">
    <property name="Class" value="Loot"/>
    <!-- Reuse an existing loot list that already works in traders -->
    <property name="LootList" value="cntGunRackLargeGuns01"/>
  </append>

  <append xpath="/blocks/block[@name='cntDisplayCaseNoLootMiddl02']">
    <property name="Class" value="Loot"/>
    <property name="LootList" value="cntGunRackLargeGuns01"/>
  </append>

  <append xpath="/blocks/block[@name='cntDisplayCaseNoLootRight']">
    <property name="Class" value="Loot"/>
    <property name="LootList" value="cntGunRackLargeGuns01"/>
  </append>





  <!-- ===== Pallet cartons ===== -->
  <append xpath="/blocks/block[@name='palletCartonMilitaryCap']">
      <property name="Class" value="Loot"/>
      <property name="LootList" value="daPalletAmmo"/>
  </append>

  <append xpath="/blocks/block[@name='palletCartonMilitaryTile']">
      <property name="Class" value="Loot"/>
      <property name="LootList" value="daPalletAmmo"/>
  </append>

  <append xpath="/blocks/block[@name='palletCartonMilitaryTileCovered']">
      <property name="Class" value="Loot"/>
      <property name="LootList" value="daPalletAmmo"/>
  </append>
<set xpath="/blocks/block[@name='cntCardboardBox']/property[@name='LootList']/@value">daPalletAmmo</set>
  <!-- ===== Mannequin ===== -->
  <append xpath="/blocks/block[@name='decoMannequinMilitaryCommando']">
      <property name="Class" value="Loot"/>
      <property name="LootList" value="daMannequinArmor"/>
      <property name="DowngradeBlock" value="decoMannequinMale"/>
      <property name="DowngradeFX" value="impact_organic_on_metal,silencefiller"/>
  </append>

