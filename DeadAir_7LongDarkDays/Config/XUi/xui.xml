  <insertAfter xpath="//window_group[@name='workstation_workbench']">
    <window_group name="workstation_cntDeadAirWeaponRepairBench"
                  controller="XUiC_WorkstationWindowGroup"
                  open_backpack_on_open="true"
                  close_compass_on_open="true"
                  defaultSelected="bp.content">

      <window name="windowDeadAirWeaponBenchCraftingList"/>
      <window name="windowDeadAirWeaponBenchCraftingInfo"/>
      <window name="windowDeadAirWeaponBenchCraftingQueue"/>
      <window name="windowDeadAirWeaponBenchOutput"/>
      <window name="windowNonPagingHeader"/>
      <window name="windowDeadAirWeaponBenchInputs"/>

    </window_group>
  </insertAfter>
</configs>